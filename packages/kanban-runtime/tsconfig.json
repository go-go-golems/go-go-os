{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "composite": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@go-go-golems/os-core": ["../engine/src"],
      "@go-go-golems/os-core/*": ["../engine/src/*"],
      "@go-go-golems/os-scripting": ["../hypercard-runtime/src"],
      "@go-go-golems/os-scripting/*": ["../hypercard-runtime/src/*"],
      "@go-go-golems/os-ui-cards": ["../ui-runtime/src"],
      "@go-go-golems/os-ui-cards/*": ["../ui-runtime/src/*"],
      "@go-go-golems/os-widgets": ["../rich-widgets/src"],
      "@go-go-golems/os-widgets/*": ["../rich-widgets/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "src/**/*.stories.tsx", "src/__tests__"],
  "references": [{ "path": "../engine" }, { "path": "../hypercard-runtime" }, { "path": "../ui-runtime" }, { "path": "../rich-widgets" }]
}
