{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "react": ["../../packages/engine/node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": ["../../packages/engine/node_modules/@types/react/jsx-runtime.d.ts"],
      "react/jsx-dev-runtime": ["../../packages/engine/node_modules/@types/react/jsx-dev-runtime.d.ts"],
      "@go-go-golems/os-shell": ["../../packages/desktop-os/src"],
      "@go-go-golems/os-shell/*": ["../../packages/desktop-os/src/*"],
      "@go-go-golems/os-core": ["../../packages/engine/src"],
      "@go-go-golems/os-core/*": ["../../packages/engine/src/*"],
      "@go-go-golems/os-scripting": ["../../packages/hypercard-runtime/src"],
      "@go-go-golems/os-scripting/*": ["../../packages/hypercard-runtime/src/*"]
    }
  },
  "include": ["src"],
  "references": [
    { "path": "../../packages/desktop-os" },
    { "path": "../../packages/engine" },
    { "path": "../../packages/hypercard-runtime" }
  ]
}
